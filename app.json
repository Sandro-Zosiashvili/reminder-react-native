{
  "expo": {
    "name": "PayReminder",
    "slug": "payreminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E27"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.payreminder.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock PayReminder securely"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E27"
      },
      "package": "com.payreminder.app",
      "permissions": [
        "NOTIFICATIONS",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5B63D3"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow PayReminder to use Face ID."
        }
      ]
    ]
  }
}
